<Window x:Class="GestionDesRetardsEtAbseneces.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image Source="/Images/logo.jpeg" Stretch="UniformToFill" Opacity="0.7" />
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,50,0,0">
            <TextBlock Text="Time Management" FontSize="36" FontWeight="Bold" Foreground="Black" Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image Source="/Images/user.png" Width="30" Height="30" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Border Grid.Column="1" BorderBrush="#3B3B3B" BorderThickness="0 0 0 1" Padding="5 0">
                    <TextBox Width="250" x:Name="NomUser" Background="Transparent" Foreground="Black" BorderThickness="0" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Image Source="/Images/password.png" Width="30" Height="30" VerticalAlignment="Center" Margin="0,6,10,0"/>
                <Border Grid.Column="1" BorderBrush="#3B3B3B" BorderThickness="0 0 0 1" Padding="5 0">
                    <PasswordBox Width="250" x:Name="MotDePasse" Background="Transparent" Foreground="Black" BorderThickness="0" VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Ajout du message d'erreur -->
            <TextBlock x:Name="Txt_ErrorMessage" Foreground="Red" Margin="0,10,0,0" Visibility="Collapsed"/>

            <Button x:Name="LoginButton" Content="LOG IN" Height="40" Margin="0,20,0,0" Background="#447AA0"
                    Foreground="White" FontWeight="Bold" Click="LoginButton_Click"/>

            <TextBlock Text="Forgot Password?" Foreground="#447AA0" HorizontalAlignment="Right"
                       Cursor="Hand" Margin="0,10,0,0" MouseDown="ForgotPassword_Click"/>
        </StackPanel>

    </Grid>
</Window>
