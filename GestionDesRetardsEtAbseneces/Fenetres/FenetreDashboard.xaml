<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreDashboard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="FenetreDashboard" Height="Auto" Width="Auto">
    <Window.Resources>
        <CollectionViewSource x:Key="employeViewSource"/>
    </Window.Resources>
    <Grid Margin="20" Height="Auto" Width="Auto">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Label Content="Tableau de Bord" Grid.Row="0" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="5"/>
        <Border Grid.Row="1" Grid.ColumnSpan="2" CornerRadius="8" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="10">
                    <TextBlock Text="Total Employés" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Name="TotalEmployeCount" FontSize="24" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Absences" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="AbsencesCount" FontSize="24" FontWeight="Bold" Foreground="Red"/>
                </StackPanel>
                <StackPanel Margin="10">
                    <TextBlock Text="Retards" FontSize="16" FontWeight="Bold"/>
                    <TextBlock x:Name="RetardsCount" FontSize="24" FontWeight="Bold" Foreground="Orange"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Text="Graphique des Retards" FontSize="16" FontWeight="Bold" Margin="5"/>
                <lvc:CartesianChart x:Name="RetardsChart" Margin="5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10">
            <StackPanel>
                <TextBlock Text="Graphique des Absences" FontSize="16" FontWeight="Bold" Margin="5"/>
                <lvc:CartesianChart x:Name="AbsencesChart" Margin="5"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="4" Grid.Column="0" CornerRadius="8" Background="White" BorderBrush="Gray" BorderThickness="1" Margin="10" Padding="10" Height="Auto">
            <StackPanel Height="150" Orientation="Horizontal">
                <!--<TextBlock Text="Employé" FontSize="16" />-->
                <Label FontWeight="Bold" Margin="5" Content="Employé" VerticalAlignment="Top"/>
                <ComboBox Margin="0,8,0,0" VerticalAlignment="Top" ItemsSource="{Binding Source={StaticResource employeViewSource}}" Name="ComboBox_Employe" Width="140" Height="22" IsEditable="True" DisplayMemberPath="Nom" SelectedValuePath="IdEmploye"/>
                <Button Content="Voir" VerticalAlignment="Top" Name="Btn_Voir" Margin="10,5,0,0" Width="100" Height="25" Click="Btn_Voir_Click"/>
                <lvc:PieChart  x:Name="EmployerDetailChart" Margin="10,10,0,0" Height="133" Width="255" VerticalAlignment="Top"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
