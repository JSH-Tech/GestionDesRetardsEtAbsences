<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreAbsence"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="FenetreAbsence" Height="450" Width="Auto">
    <Window.Resources>
        <CollectionViewSource x:Key="absenceViewSource"/>
        <CollectionViewSource x:Key="employeViewSource"/>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition ></RowDefinition>
        </Grid.RowDefinitions>

        <Label Content="Gestion des absences" Grid.ColumnSpan="3" HorizontalAlignment="Center" FontSize="30"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Content="Employé :" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox x:Name="ComboBox_Employe" ItemsSource="{Binding Source={StaticResource employeViewSource}}" Grid.Column="1" Margin="5" SelectedValuePath="IdEmploye" DisplayMemberPath="NomComplet"/>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Content="Date :" Grid.Column="0" VerticalAlignment="Center"/>
            <DatePicker x:Name="DatePicker_DateAbsence" Grid.Column="1" Margin="5"/>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Content="Type :" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox x:Name="ComboBox_Type" Grid.Column="1" Margin="5">
                <ComboBoxItem Content="Absence non justifiée"/>
                <ComboBoxItem Content="Congé payé"/>
                <ComboBoxItem Content="Congé non payé"/>
                <ComboBoxItem Content="Maladie"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Content="Justificaion :" Grid.Column="0" VerticalAlignment="Center"/>
            <TextBox x:Name="TextBoxJustificatif" Grid.Column="1" Margin="5"/>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Label Content="Status :" Grid.Column="0" VerticalAlignment="Center"/>
            <ComboBox x:Name="ComboBox_Status" Grid.Column="1" Margin="5">
                <ComboBoxItem Content="Valide"/>
                <ComboBoxItem Content="Non Valide"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="3" Grid.ColumnSpan="3" HorizontalAlignment="Center"  Height="35">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
                <ColumnDefinition Width="100"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Button x:Name="Btn_Ajouter" Content="Ajouter" Grid.Column="0" Margin="5" Click="Btn_Ajouter_Click"/>
            <Button Name="Btn_Modifier" Content="Modifier" Grid.Column="1" Margin="5" Click="Btn_Modifier_Click"/>
            <Button x:Name="Btn_Supprimer" Content="Supprimer" Grid.Column="2" Margin="5"/>
            <Button x:Name="Btn_Actualiser" Content="Actualiser" Grid.Column="3" Margin="5"/>
        </Grid>

        <Grid Grid.Row="4" Grid.ColumnSpan="3">
            <DataGrid Grid.Row="4" Grid.ColumnSpan="3" AutoGenerateColumns="False" Name="DataGrid_Absence" ItemsSource="{Binding Absences}">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="150" Header="Nom" Binding="{Binding IdEmployeNavigation.Nom}"/>
                    <DataGridTextColumn Width="150" Header="Prenom" Binding="{Binding IdEmployeNavigation.Prenom}"/>
                    <DataGridTextColumn Width="130" Header="Date" Binding="{Binding DateAbsence}"/>
                    <DataGridTextColumn Width="150" Header="Type" Binding="{Binding TypeAbsence}"/>
                    <DataGridTextColumn Width="150" Header="Justificatif" Binding="{Binding Justification}"/>
                    <DataGridTextColumn Width="130" Header="Statut" Binding="{Binding StatutText}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
