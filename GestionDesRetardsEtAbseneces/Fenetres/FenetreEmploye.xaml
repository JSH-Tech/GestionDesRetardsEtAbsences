<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreEmploye"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Title="FenetreEmploye" Height="450" Width="800">
    <Grid Margin="10">

        <!-- En-tête -->
        <Border Background="#447AA0" Height="60" VerticalAlignment="Top" CornerRadius="10">
            <TextBlock Text="Gestion des Employés" Foreground="White" FontSize="24" FontWeight="Bold" 
           HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <Grid Margin="0,80,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <!-- Formulaire -->
            <Border Background="White" Padding="20" CornerRadius="10" BorderBrush="#F7F9FF" BorderThickness="1" Grid.Row="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nom :" FontWeight="Bold" Grid.Column="0" Grid.Row="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtNom" Height="30" BorderBrush="#2980B9" Grid.Column="1" Grid.Row="0" Margin="5"/>

                    <TextBlock Text="Prénom :" FontWeight="Bold" Grid.Column="2" Grid.Row="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPrenom" Height="30" BorderBrush="#2980B9" Grid.Column="3" Grid.Row="0" Margin="5"/>

                    <TextBlock Text="Email :" FontWeight="Bold" Grid.Column="0" Grid.Row="1" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtEmail" Height="30" BorderBrush="#2980B9" Grid.Column="1" Grid.Row="1" Margin="5"/>

                    <TextBlock Text="Mot de passe :" FontWeight="Bold" Grid.Column="2" Grid.Row="1" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="MotDePasse" Height="30" BorderBrush="#2980B9" Grid.Column="3" Grid.Row="1" Margin="5"/>

                    <TextBlock Text="Rôle :" FontWeight="Bold" Grid.Column="0" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="RoleComboBox" Height="30" Grid.Column="1" Grid.Row="2" Margin="5">
                        <ComboBoxItem Content="RH"/>
                        <ComboBoxItem Content="Employé"/>
                        <ComboBoxItem Content="Manager"/>
                    </ComboBox>

                    <TextBlock Text="Statut :" FontWeight="Bold" Grid.Column="2" Grid.Row="2" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatutComboBox" Height="30" Grid.Column="3" Grid.Row="2" Margin="5">
                        <ComboBoxItem Content="Actif"/>
                        <ComboBoxItem Content="En congé"/>
                        <ComboBoxItem Content="Suspendu"/>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Boutons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="1" Margin="10">
                <Button x:Name="btnAjouter" Width="120" Height="40" Background="#27AE60" Foreground="White" FontWeight="Bold"
                Margin="5 " Click="btnAjouter_Click"  >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✅ " />
                        <TextBlock Text="Ajouter" />
                    </StackPanel>
                </Button>
                <Button x:Name="btnModifier" Width="120" Height="40" Background="Blue" Foreground="White" FontWeight="Bold" 
                Margin="5" IsEnabled="False"  Click="btnModifier_Click" >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏️ " />
                        <TextBlock Text="Modifier" />
                    </StackPanel>
                </Button>
                <Button x:Name="btnAnnuler" Width="120" Height="40" Background="red" Foreground="White" FontWeight="Bold"
                Margin="5"  Click="btnAnnuler_Click" >
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌ " />
                        <TextBlock Text="Annuler" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Tableau des employés -->
            <DataGrid x:Name="EmployeDataGrid" Grid.Row="2" Margin="0,20,0,20" AutoGenerateColumns="False" 
              HeadersVisibility="Column" BorderBrush="#2980B9" BorderThickness="1"
              Background="White" SelectionChanged="EmployeDataGrid_SelectionChanged" 
              SelectionMode="Single" AlternationCount="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom"  Width="100" Binding="{Binding Nom}"/>
                    <DataGridTextColumn Header="Prénom" Width="100"  Binding="{Binding Prenom}"/>
                    <DataGridTextColumn Header="Email" Width="150"  Binding="{Binding Email}"/>
                    <DataGridTextColumn Header="Rôle " Width="150"  Binding="{Binding RoleEmploye }"/>
                    <DataGridTextColumn Header="Statut" Width="100"  Binding="{Binding Statut}"/>

                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        </Grid>
</Window>
