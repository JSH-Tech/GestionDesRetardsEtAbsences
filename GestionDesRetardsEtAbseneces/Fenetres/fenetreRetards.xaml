<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.fenetreRetards"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Title="fenetreRetards" Height="800" Width="Auto" Background="#1F618D">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gestion des Retards" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

      
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,5">
            <Label Content="Employé :" Width="120" FontWeight="Bold"/>
            <ComboBox Name="cmbEmploye" Width="250" Height="30" Background="White" BorderBrush="#BDC3C7"/>
        </StackPanel>

        <!-- Date du retard -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,5">
            <Label Content="Date :" Width="120" FontWeight="Bold"/>
            <DatePicker Name="dpDateRetard" Width="250" Height="30" Background="White" BorderBrush="#BDC3C7"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" Margin="0,5">
            <Label Content="Heure début :" Width="120" FontWeight="Bold"/>
            <TextBox Name="txtHeureDebut" Width="100" Height="30" BorderBrush="#BDC3C7" Background="White"
             Text="{Binding HeureDebut, StringFormat=HH:mm}" />

            <Label Content="Heure fin :" Width="100" FontWeight="Bold" Margin="10,0,0,0"/>
            <TextBox Name="txtHeureFin" Width="100" Height="30" BorderBrush="#BDC3C7" Background="White"
             Text="{Binding HeureFin, StringFormat=HH:mm}" />
        </StackPanel>

        <!-- Justification -->
        <StackPanel Grid.Row="4" Margin="0,5">
            <Label Content="Justification :" FontWeight="Bold"/>
            <TextBox Name="txtJustification" Height="80" TextWrapping="Wrap" Background="White" 
                     BorderBrush="#BDC3C7" Padding="5"/>
        </StackPanel>

        <!-- Validation -->
        <StackPanel Orientation="Vertical" Grid.Row="5" Margin="0,5" >
            <CheckBox Name="chkValide" Content="Validé" FontWeight="Bold"/>
        </StackPanel>

        <!-- Boutons d'action -->
        <StackPanel Orientation="Horizontal" Grid.Row="6" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Name="btnAjouter" Content="➕ Ajouter" Width="120" Height="40" Background="#3498DB"
                    Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Click="btnAjouter_Click" Style="{StaticResource StyledButton}"/>
            <Button Name="btnModifier" Content="✏️ Modifier" Width="120" Height="40" Background="#27AE60"
                    Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Margin="10,0,0,0" Click="btnModifier_Click" Style="{StaticResource StyledButton}"/>
            <Button Name="btnSupprimer" Content="🗑️ Supprimer" Width="120" Height="40" Background="#E74C3C"
                    Foreground="White" FontWeight="Bold" BorderBrush="Transparent" Margin="10,0,0,0" Click="btnSupprimer_Click" Style="{StaticResource StyledButton}"/>
            <Button Content="🔃Actualiser" Name="Btn_Actualiser" Margin="10,0,00,0" Width="100" Background="#8E44AD"
        Style="{StaticResource StyledButton}" Click="Btn_Actualiser_Click"/>
        </StackPanel>
        <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Height="Auto" Width="Auto">-->
            <DataGrid  Grid.Row="7" Name="DataGrid_Retard" Margin="5" AutoGenerateColumns="False" SelectionChanged="DataGrid_Retard_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nom" Binding="{Binding IdEmployeNavigation.Nom}" Width="150"/>
                    <!--<DataGridTextColumn Header="Prénom" Binding="{Binding IdEmplyeNavigation.Prenom}" Width="150"/>-->
                    <DataGridTextColumn Header="Heure debut retard" Binding="{Binding HeureDebut}" Width="150"/>
                    <DataGridTextColumn Header="Heure Fin retards" Binding="{Binding HeureFin}" Width="150"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding DateRetard}" Width="150"/>
                    <DataGridTextColumn Header="Status de la Justification" Binding="{Binding Justification }" Width="150"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Valide}" Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        <!--</StackPanel>-->
    </Grid>

</Window>
