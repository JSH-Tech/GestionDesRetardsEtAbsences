<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreRapport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="RAPPORT" Height="800" Width="1200"  Background="AliceBlue">
    <Window.Resources>
        <CollectionViewSource x:Key="rapportViewSource"/>
        <CollectionViewSource x:Key="employeViewSource"/>
    </Window.Resources>
    <Grid Margin="10">

        <Border Background="#1F618D" Height="50" VerticalAlignment="Top" CornerRadius="5">
            <TextBlock Text="Gestion des Rapports" Foreground="White" FontSize="20" FontWeight="Bold"
                HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <Grid Margin="0,70,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <StackPanel Grid.Column="0" Grid.Row="0" Margin="5">
                <Label Content="Période du rapport" FontWeight="Bold"/>
                <ComboBox Name="ComboBoxPeriode" Width="200">
                    <ComboBoxItem>Hebdomadaire</ComboBoxItem>
                    <ComboBoxItem>Mensuelle</ComboBoxItem>
                    <ComboBoxItem>Trimestrielle</ComboBoxItem>
                    <ComboBoxItem>Semestrielle</ComboBoxItem>
                    <ComboBoxItem>Annuelle</ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="0" Margin="5">
                <Label Content="Date de génération" FontWeight="Bold"/>
                <DatePicker Name="DatePickerDateGeneration" Width="200"/>
            </StackPanel>


            <StackPanel Grid.Column="0" Grid.Row="1" Margin="5">
                <Label Content="Employé" FontWeight="Bold"/>
                <ComboBox IsEditable="True" Name="ComboBoxEmploye" Width="200"
                   DisplayMemberPath="Nom" SelectedValuePath="IdEmploye"
                   ItemsSource="{Binding Source={StaticResource employeViewSource}}"/>
            </StackPanel>

            <!-- Contenu du rapport -->
            <StackPanel Grid.Column="1" Grid.Row="1" Margin="5">
                <Label Content="Contenu du rapport" FontWeight="Bold"/>
                <RichTextBox x:Name="RichTextBoxContenuRapport" Height="100" Width="250"/>
            </StackPanel>


            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2" Grid.ColumnSpan="2" Margin="10">
                <Button Content="Générer" Name="Btn_Generer" Width="100" Click="Btn_Generer_Click" Style="{StaticResource StyledButton}"
                 Background="#27AE60" Foreground="White" FontWeight="Bold"/>
                <Button Content="Modifier" Name="Btn_Modifier" Width="100" Click="Btn_Modifier_Click" 
                 Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                <Button Content="Supprimer" Name="Btn_Supprimer" Width="100" Click="Btn_Supprimer_Click" Style="{StaticResource StyledButton}"
                 Background="Red" Foreground="White" FontWeight="Bold"/>
                <Button Content="Imprimer" Name="Btn_Imprimer" Width="100" Click="Btn_Imprimer_Click" Style="{StaticResource StyledButton}"
                 Background="Gray" Foreground="White" FontWeight="Bold"/>
                <Button Content="Actualiser" Name="Btn_Actualiser" Width="100" Click="Btn_Actualiser_Click" Style="{StaticResource StyledButton}"
                 Background="#8E44AD" Foreground="White" FontWeight="Bold"/>
            </StackPanel>

            <!-- Tableau des Rapports -->
            <DataGrid HorizontalAlignment="Stretch" Grid.Row="3" Grid.ColumnSpan="2" Margin="5"
               Name="DatagridRapport" ItemsSource="{Binding Source={StaticResource rapportViewSource}}"
               AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True"
               SelectionChanged="DatagridRapport_SelectionChanged"
               RowBackground="WhiteSmoke" AlternatingRowBackground="#D6EAF8"
               FontSize="14" FontWeight="Bold"
               CanUserResizeColumns="True" CanUserResizeRows="False"
               CanUserSortColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Période" Width="150" Binding="{Binding PeriodeRapport}"/>
                    <DataGridTextColumn Header="Date" Width="150" Binding="{Binding DateGeneration}"/>
                    <DataGridTextColumn Header="Contenu" Width="200" Binding="{Binding ContenuRapport}"/>
                    <DataGridTextColumn Header="Employé" Width="150" Binding="{Binding IdEmployeNavigation.Nom}"/>
                </DataGrid.Columns>
            </DataGrid>

        </Grid>
    </Grid>
</Window>
