<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreRapport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Title="RAPPORT" Height="450" Width="700" Background="SkyBlue">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Content="Gerer les rapports" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontSize="30"/>
        
        <WrapPanel Grid.Column="0" Grid.Row="1" Margin="0,10,0,0">
            <Label Content="Periode du rapport"/>
            <ComboBox Width="150">
                <ComboBoxItem>Hebdomadaire</ComboBoxItem>
                <ComboBoxItem>Mensuelle</ComboBoxItem>
                <ComboBoxItem>Trimestrielle</ComboBoxItem>
                <ComboBoxItem>Semestrielle</ComboBoxItem>
                <ComboBoxItem>Annuelle</ComboBoxItem>
            </ComboBox>
        </WrapPanel>

        <WrapPanel Grid.Column="0" Grid.Row="2" Margin="0,10,0,0">
            <Label Content="Date de generation"/>
            <DatePicker Width="150"/>
        </WrapPanel>

        <WrapPanel Grid.Column="1" Grid.Row="1" Margin="0,10,0,0">
            <Label Content="Employe"/>
            <ComboBox Width="200">
                <ComboBoxItem>Employe1</ComboBoxItem>
                <ComboBoxItem>Employe1</ComboBoxItem>
                <ComboBoxItem>Employe1</ComboBoxItem>
            </ComboBox>
        </WrapPanel>

        <DockPanel Grid.Column="1" Grid.Row="2" Margin="0,10,5,0" Height="150">
            <Label Content="Contenu"/>
            <RichTextBox/>
        </DockPanel>

        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Button Content="Envoyer" Name="Btn_Envoyer" Margin="0,0,10,0" Width="100"/>
            <Button Content="Modifier" Name="Btn_Modifier" Margin="0,0,10,0" Width="100"/>
            <Button Content="Supprimer" Name="Btn_Supprimer" Margin="0,0,10,0" Width="100"/>
            <Button Content="Actualiser" Name="Btn_Actualiser" Margin="0,0,00,0" Width="100"/>
        </StackPanel>
        <WrapPanel HorizontalAlignment="Center" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <DataGrid>
                <DataGrid.Columns>
                    <DataGridTextColumn Header='Periode du rapport' Width="150"/>
                    <DataGridTextColumn Header='Date de generation' Width="150"/>
                    <DataGridTextColumn Header='Contenu du rapport' Width="150"/>
                    <DataGridTextColumn Header='Employé' Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </WrapPanel>
    </Grid>
</Window>
