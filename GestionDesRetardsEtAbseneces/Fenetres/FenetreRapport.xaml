<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreRapport"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Loaded="Window_Loaded"
        Title="RAPPORT" Height="450" Width="Auto" >
    <Window.Resources>
        <CollectionViewSource x:Key="rapportViewSource"/>
        <CollectionViewSource x:Key="employeViewSource"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Label Content="Gerer les rapports" Grid.ColumnSpan="2" HorizontalAlignment="Center" FontSize="30"/>
        
        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Grid.Column="0" Grid.Row="1" Margin="0,10,0,0">
            <Label Content="Periode du rapport"/>
            <ComboBox Name="ComboBoxPeriode" Width="150">
                <ComboBoxItem>Hebdomadaire</ComboBoxItem>
                <ComboBoxItem>Mensuelle</ComboBoxItem>
                <ComboBoxItem>Trimestrielle</ComboBoxItem>
                <ComboBoxItem>Semestrielle</ComboBoxItem>
                <ComboBoxItem>Annuelle</ComboBoxItem>
            </ComboBox>
        </StackPanel>

        <StackPanel Height="30" VerticalAlignment="Top" HorizontalAlignment="Center" Orientation="Horizontal" Grid.Column="0" Grid.Row="2" Margin="0,10,0,0">
            <Label Content="Date de generation"/>
            <DatePicker Name="DatePickerDateGeneration" Width="150" />
        </StackPanel>

        <StackPanel HorizontalAlignment="Center"  Orientation="Horizontal" Grid.Column="1" Grid.Row="1" Margin="0,10,0,0">
            <Label Content="Employe"/>
            <ComboBox IsEditable="True" Name="ComboBoxEmploye" Width="200" DisplayMemberPath="Nom" SelectedValuePath="IdEmploye" ItemsSource="{Binding Source={StaticResource employeViewSource}}"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Center" Grid.Column="1" Grid.Row="2" Margin="0,10,5,0" Height="150">
            <Label Content="Contenu"/>
            <RichTextBox x:Name="RichTextBoxContenuRapport" Width="200"/>
        </StackPanel>

        <StackPanel  Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Button Content="Generer" Name="Btn_Generer" Margin="0,0,10,0" Width="100" Click="Btn_Generer_Click" RenderTransformOrigin="19.156,11.21"/>
            <Button Content="Modifier" Name="Btn_Modifier" Margin="0,0,10,0" Width="100" Click="Btn_Modifier_Click"/>
            <Button Content="Supprimer" Name="Btn_Supprimer" Margin="0,0,10,0" Width="100" Click="Btn_Supprimer_Click"/>
            <Button Content="Imprimer" Name="Btn_Imprimer" Width="100" Click="Btn_Imprimer_Click"/>
            <Button Content="Actualiser" Name="Btn_Actualiser" Margin="0,0,10,0" Width="100" Click="Btn_Actualiser_Click"/>
            
        </StackPanel>

            <DataGrid  HorizontalAlignment="Center" Grid.Column="0" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,10,0,0" Name="DatagridRapport" ItemsSource="{Binding Source={StaticResource rapportViewSource}}" AutoGenerateColumns="False" SelectionMode="Single" IsReadOnly="True" SelectionChanged="DatagridRapport_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header='Periode du rapport' Width="150" Binding="{Binding PeriodeRapport}"/>
                    <DataGridTextColumn Header='Date de generation' Width="150" Binding="{Binding DateGeneration}"/>
                    <DataGridTextColumn Header='Contenu du rapport' Width="150" Binding="{Binding ContenuRapport}"/>
                    <DataGridTextColumn Header='Employé' Width="150" Binding="{Binding IdEmployeNavigation.Nom}"/>
                </DataGrid.Columns>
            </DataGrid>

    </Grid>
</Window>
