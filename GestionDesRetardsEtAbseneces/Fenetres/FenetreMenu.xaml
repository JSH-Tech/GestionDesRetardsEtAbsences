<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Title="FenetreMenu" Height="700" Width="1000" Background="AliceBlue">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre avec un cadre stylisé -->
        <Label x:Name="LabelBienvenu"  
               Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="Black"
               HorizontalAlignment="Center" Margin="10"/>

        <!-- Section principale -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Boutons stylisés -->
            <Button x:Name="Btn_Employes"  Content="👤 Gestion des Employés" Grid.Row="0" Grid.Column="0" Style="{StaticResource StyledButton}" Click="Btn_Employes_Click"/>
            <Button  x:Name="Btn_Retard" Content="⏳ Suivi des Retards" Grid.Row="1" Grid.Column="0" Style="{StaticResource StyledButton}" Click="Btn_Retard_Click"/>

            <!-- Image animée -->
            <Image Grid.Column="1" Source="/Images/pi.jpg" Grid.RowSpan="5" Name="MainImage" Opacity="0"/>

            <Button x:Name="Btn_Rapports"  Content="📑 Rapports " Grid.Row="0" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_Rapports_Click"/>
            <Button  Content="📅 Demande de Congés" Grid.Row="1" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_DemandeConges_Click"/>
            <Button  x:Name="Btn_ValidationConges"  Content="✅ Validation des Congés" Grid.Row="3" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_ValidationConges_Click"/>
            <Button x:Name="Btn_Notifications" Content="🔔 Mes Notifications" Grid.Row="2" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_NotificationsEmploye_Click"/>
            <Button  x:Name="Btn_Dashboard" Content="📊 Tableau de Bord" Grid.Row="3" Style="{StaticResource StyledButton}" Click="Btn_Dashboard_Click"/>
            <Button Content="Deconnexion" Grid.Row="4" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_Deconnexion_Click"/>
            <Button x:Name="Btn_Absence" Content="⏱Suivi des absences" Grid.Row="4" Style="{StaticResource StyledButton}" Click="Btn_Absence_Click"/>
        </Grid>

        <!-- Pied de page avec l'heure -->
        <TextBlock Grid.Row="2" Name="FooterText" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="10"/>

    </Grid>

    <!-- Animation de l'image -->
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="MainImage" Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:2"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>


</Window>
