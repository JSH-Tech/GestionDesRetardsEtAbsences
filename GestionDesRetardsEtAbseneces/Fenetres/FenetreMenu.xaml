<Window x:Class="GestionDesRetardsEtAbseneces.Fenetres.FenetreMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestionDesRetardsEtAbseneces.Fenetres"
        mc:Ignorable="d"
        Title="FenetreMenu" Height="700" Width="1000" Background="AliceBlue">
    
    <Grid Margin="20">
        <!-- Définition des lignes -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <!-- Titre centré -->
        <Label x:Name="LabelBienvenu" Content="Bienvenue !" 
               Grid.Row="0" FontSize="24" FontWeight="Bold" Foreground="Black"
               HorizontalAlignment="Center" Margin="10"/>

        <!-- Section des boutons -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Colonne 1 -->
            <Button Content="👤 Gestion des Employés" Name="Btn_Employes" Grid.Row="0" Grid.Column="0" Style="{StaticResource StyledButton}" Click="Btn_Employes_Click"/>
            <Button Content="⏳ Suivi des Retards" Name="Btn_Retard" Grid.Row="1" Grid.Column="0" Style="{StaticResource StyledButton}" Click="Btn_Retard_Click" />
            <Image Grid.Column="1" Source="/Fenetres/pmlogo.webp" Grid.RowSpan="5"/>
            <!-- Colonne 2 -->
            <Button Content="📑 Rapports " Name="Btn_Rapports" Grid.Row="0" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_Rapports_Click" />
            <Button Content="📅 Demande de Congés" Name="Btn_DemandeConges" Grid.Row="1" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_DemandeConges_Click" />
            <Button Content="✅ Validation des Congés" Name="Btn_ValidationConges" Grid.Row="3" Grid.Column="2" Style="{StaticResource StyledButton}" />
            <Button Content="🔔 Centre de Notifications" Name="Btn_Notifications" Grid.Row="2" Style="{StaticResource StyledButton}" HorizontalAlignment="Center" Click="Btn_Notifications_Click"/>
            <Button Content="🔔 Mes Notifications" Name="Btn_NotificationsEmploye" Grid.Row="2" Grid.Column="2"  Style="{StaticResource StyledButton}" HorizontalAlignment="Center" Click="Btn_NotificationsEmploye_Click"/>
            <Button Content="📊 Tableau de Bord" Name="Btn_Dashboard" Grid.Row="3" Style="{StaticResource StyledButton}" Click="Btn_Dashboard_Click" />
            <Button Content="Deconnexion" Name="Btn_Deconnexion" Grid.Row="4" Grid.Column="2" Style="{StaticResource StyledButton}" Click="Btn_Deconnexion_Click" />
            <Button Content="Suivi des absences" Name="Btn_Absence" Grid.Row="4" Style="{StaticResource StyledButton}" Click="Btn_Absence_Click"/>

        </Grid>
    </Grid>
</Window>
